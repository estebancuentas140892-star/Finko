{
  "name": "finko-claude",
  "version": "1.0.0",
  "description": "PWA offline-first de gestión financiera personal para Colombia",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint modules/ tests/",
    "format": "prettier --write \"**/*.{js,css,html,md,json}\"",
    "serve": "python -m http.server 8080",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lighthouse": "node scripts/lighthouse.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^2.1.0",
    "axe-core": "^4.11.4",
    "eslint": "^9.6.0",
    "happy-dom": "^15.11.7",
    "lighthouse": "^13.3.0",
    "prettier": "^3.3.0",
    "vitest": "^2.1.0"
  }
}
