# No instalar paquetes publicados hace menos de 7 días.
# Atrapa la mayoría de reports de malware antes de que llegue a tu máquina.
minimum-release-age=7

# Bloquea por defecto scripts de install (postinstall/preinstall).
# Los paquetes aprobados se registran en pnpm-lock.yaml via "pnpm approve-builds".
# Paquetes actualmente aprobados: esbuild (requerido por @vitest/coverage-v8).
# Para aprobar nuevos: pnpm approve-builds <pkg>

# CI debe respetar el lockfile exacto.
frozen-lockfile=true

# Otras buenas prácticas
strict-peer-dependencies=false
auto-install-peers=true
